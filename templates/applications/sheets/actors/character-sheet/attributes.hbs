<section class="tab {{tab.id}} {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
	<div class="characteristics-and-impairments">
		<h2 class="sheet-title">
			{{localize "CHARACTER.TABS.attributes"}}
		</h2>

		<div>
			<div class="impairments">
				{{>systems/wfrp3e/templates/applications/sheets/actors/partials/impairment.hbs
						impairment=fields.impairments.fields.fatigue
						token="systems/wfrp3e/assets/images/fatigue.webp"}}

				{{>systems/wfrp3e/templates/applications/sheets/actors/partials/impairment.hbs
						impairment=fields.impairments.fields.stress
						token="systems/wfrp3e/assets/images/stress.webp"}}
			</div>

			<div class="characteristics">
				{{#each fields.characteristics.fields as |characteristic char|}}
					{{>systems/wfrp3e/templates/applications/sheets/actors/partials/characteristic.hbs characteristic=characteristic}}
				{{/each}}
			</div>
		</div>
	</div>

	<div class="skills" data-item-type="skill">
		<h2 class="sheet-title">
			{{localize "SKILL.plural"}}

			<a data-action="addItem"
			   data-tooltip="{{localize 'ACTOR.ACTIONS.addItem' type=(localize "TYPES.Item.skill")}}">
				<span class="fa-solid fa-plus"></span>
			</a>
		</h2>

		{{#if skills}}
			<div class="skill table">
				<div class="table-header">
					<div class="name">
						{{localize "Name"}}
					</div>

					<div class="characteristic">
						{{localize "SKILL.FIELDS.characteristic.abbreviation"}}
					</div>

					<div class="training-level">
						{{localize "SKILL.FIELDS.trainingLevel.label"}}
					</div>

					<div class="buttons"></div>
				</div>

				<div class="table-body">
					{{#each skills as |skill sk|}}
						{{>systems/wfrp3e/templates/applications/sheets/actors/partials/skill-row.hbs skill=skill}}
					{{/each}}
				</div>
			</div>
		{{else unless character}}
			<p>{{{localize "CHARACTER.WARNINGS.noSkill" actor=source.name}}}</p>

			<button data-action="addBasicSkills">
				{{localize "CHARACTER.ACTIONS.addBasicSkills"}}
			</button>
		{{/if}}
	</div>

	<div class="attributes">
		<div class="attributes-subdivision">
			{{>systems/wfrp3e/templates/applications/sheets/actors/partials/attribute.hbs attribute=fields.wounds}}

			{{>systems/wfrp3e/templates/applications/sheets/actors/partials/attribute.hbs attribute=fields.corruption}}

			{{>systems/wfrp3e/templates/applications/sheets/actors/partials/attribute.hbs attribute=fields.fortune}}
		</div>

		<div class="attributes-subdivision">
			<fieldset class="attribute {{attribute.name}}">
				<legend>{{localize "ACTOR.FIELDS.defenceValue.label"}}</legend>

				<p>{{system.totalDefence}}</p>
			</fieldset>

			<fieldset class="attribute {{attribute.name}}">
				<legend>{{localize "ACTOR.FIELDS.soakValue.label"}}</legend>

				<p>{{system.totalSoak}}</p>
			</fieldset>
		</div>

		<div class="stance-meter">
			<h2 class="sheet-title">
				<a class="stance-meter-segment"
				   data-action="adjustStanceMeter"
				   data-stance="conservative"
				   data-tooltip="{{localize 'ACTOR.ACTIONS.adjustConservativeSegment'}}">
					<img class="stance-conservative"
						 src="systems/wfrp3e/assets/images/stance-conservative.webp"
						 alt="{{localize 'CHARCTER.SHEET.conservativeSegment'}}"
						 height="27" />
				</a>

				{{localize "ACTOR.FIELDS.stance.label"}}

				<a class="stance-meter-segment"
				   data-action="adjustStanceMeter"
				   data-stance="reckless"
				   data-tooltip="{{localize 'ACTOR.ACTIONS.adjustRecklessSegment'}}">
					<img class="stance-reckless"
						 src="systems/wfrp3e/assets/images/stance-reckless.webp"
						 alt="{{localize 'CHARCTER.SHEET.recklessSegment'}}"
						 height="27" />
				</a>
			</h2>

			<div class="stance-meter-segment-container">
				{{#for system.stanceMeter.conservative (increment system.stanceMeter.reckless 1) 1}}
					<label class="stance-meter-segment{{#if (eq @root.source.system.stance.current this)}} selected{{else if (eq @root.system.stance.current this)}} active{{/if}}"
						   data-tooltip="{{localize 'ACTOR.ACTIONS.adjustStance'}}">
						<img class="stance-{{#if (lt this 0)}}conservative{{else if (gt this 0)}}reckless{{else}}neutral{{/if}}"
							 src="systems/wfrp3e/assets/images/stance-{{#if (lt this 0)}}conservative{{else if (gt this 0)}}reckless{{else}}neutral{{/if}}.webp" height="27" />

						<input name="system.stance.current"
							   value="{{this}}"
							   type="radio"
							   {{checked (eq @root.source.system.stance.current this)}}/>
					</label>
				{{/for}}
			</div>
		</div>

		<div class="attributes-subdivision">
			{{#if system.priest}}
				<fieldset class="attribute favour">
					<div class="form-group">
						<label for="{{concat rootId "-" fields.favour.fieldPath}}">
							<a data-action="curryFavour" data-tooltip="{{localize 'CHARACTER.ACTIONS.curryFavour'}}">
								{{fields.favour.label}}

								<span class="fa-solid fa-hands-praying"></span>
							</a>
						</label>

						<div class="form-fields">
							{{formInput fields.favour
										value=system.favour
										id=(concat rootId "-" fields.favour.fieldPath)}}
						</div>
					</div>
				</fieldset>
			{{/if}}

			{{#if system.wizard}}
				<fieldset class="attribute power">
					<div class="form-group">
						<label for="{{concat rootId "-" fields.power.fieldPath}}">
							<a data-action="channelPower" data-tooltip="{{localize 'CHARACTER.ACTIONS.channelPower'}}">
								{{fields.power.label}}

								<span class="fa-solid fa-bolt"></span>
							</a>
						</label>

						<div class="form-fields">
							{{formInput fields.power
										value=system.power
										id=(concat rootId "-" fields.power.fieldPath)}}
						</div>
					</div>
				</fieldset>
			{{/if}}
		</div>
	</div>
</section>
